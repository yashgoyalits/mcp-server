# Server
# Render sets this automatically in production — only needed for local dev.
PORT=3000

# Cloudflare R2 — S3-compatible API credentials.
# Generate via: Cloudflare Dashboard → R2 → Manage API Tokens
#   → Create API Token → "Object Read & Write" → limit to your bucket.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
